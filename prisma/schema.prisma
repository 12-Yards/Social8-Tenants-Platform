generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ArticleCategories {
  id          Int       @id @default(autoincrement())
  name        String
  icon        String?   @default("folder")
  orderIndex  Int?      @default(0) @map("order_index")
  createdAt   DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@unique([name, tenantId])
  @@map("article_categories")
}

model ArticleLikes {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  articleId  String @db.VarChar(36) @map("article_id")
  userId     String @db.VarChar(255) @map("user_id")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("article_likes")
}

model ArticleSections {
  id              String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  articleId       String  @db.VarChar(36) @map("article_id")
  orderIndex      Int @map("order_index")
  sectionType     String @map("section_type")
  heading         String?
  content         String?
  mediaUrls       Json?   @default("[]") @map("media_urls")
  mediaCaptions   Json?   @default("[]") @db.Json @map("media_captions")
  muxPlaybackId   String? @map("mux_playback_id")
  muxAssetId      String? @map("mux_asset_id")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("article_sections")
}

model Articles {
  id             String @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  title          String
  slug           String
  category       String
  excerpt        String
  content        String
  heroImageUrl   String @map("hero_image_url")
  publishedAt    String @map("published_at")
  author         String
  readingTime    Int @map("reading_time")
  boostedLikes   Int?   @default(0) @map("boosted_likes")
  imageUrls      Json?  @default("[]") @map("image_urls")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@unique([slug, tenantId])
  @@map("articles")
}

model Comments {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  articleId         String    @db.VarChar(36) @map("article_id")
  userId            String    @db.VarChar(255) @map("user_id")
  content           String
  createdAt         DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  parentCommentId   String?   @db.VarChar(36) @map("parent_comment_id")
  updatedAt         DateTime? @db.Timestamp(6) @map("updated_at")
  edited            Boolean?  @default(false)
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("comments")
}

model CompetitionBrackets {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId      String    @unique @db.VarChar(36) @map("event_id")
  totalRounds  Int @map("total_rounds")
  createdAt    DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("competition_brackets")
}

model CompetitionMatches {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  roundId                     String    @db.VarChar(36) @map("round_id")
  matchNumber                 Int @map("match_number")
  team1Id                     String?   @db.VarChar(36) @map("team1_id")
  team2Id                     String?   @db.VarChar(36) @map("team2_id")
  winnerId                    String?   @db.VarChar(36) @map("winner_id")
  score1                      Int?
  score2                      Int?
  createdAt                   DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  resultSubmittedByTeamId     String?   @db.VarChar(36) @map("result_submitted_by_team_id")
  proposedWinnerId            String?   @db.VarChar(36) @map("proposed_winner_id")
  resultSubmittedByUserId     String?   @db.VarChar(36) @map("result_submitted_by_user_id")
  resultConfirmedByUserId     String?   @db.VarChar(36) @map("result_confirmed_by_user_id")
  resultConfirmedAt           DateTime? @db.Timestamp(6) @map("result_confirmed_at")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("competition_matches")
}

model CompetitionRounds {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  bracketId    String    @db.VarChar(36) @map("bracket_id")
  roundNumber  Int @map("round_number")
  roundName    String @map("round_name")
  deadline     DateTime? @db.Timestamp(6)
  createdAt    DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("competition_rounds")
}

model CompetitionTeams {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId          String    @db.VarChar(36) @map("event_id")
  teamNumber       Int @map("team_number")
  player1EntryId   String?   @db.VarChar(40) @map("player1_entry_id")
  player2EntryId   String?   @db.VarChar(40) @map("player2_entry_id")
  createdAt        DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  player3EntryId   String?   @db.VarChar(40) @map("player3_entry_id")
  player4EntryId   String?   @db.VarChar(40) @map("player4_entry_id")
  player5EntryId   String?   @db.VarChar(40) @map("player5_entry_id")
  player6EntryId   String?   @db.VarChar(40) @map("player6_entry_id")
  teamStableford   Int? @map("team_stableford")
  teeTime          String?   @db.VarChar(10) @map("tee_time")
  teamHandicap     Int? @map("team_handicap")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("competition_teams")
}

model ConnectionNotifications {
  id              Int       @id @default(autoincrement())
  userId          String    @db.VarChar(255) @map("user_id")
  type            String
  connectionId    Int? @map("connection_id")
  isRead          Boolean?  @default(false) @map("is_read")
  createdAt       DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  messageId       Int? @map("message_id")
  fromUserId      String?   @db.VarChar(255) @map("from_user_id")
  eventId         String?   @db.VarChar(255) @map("event_id")
  teamId          String?   @db.VarChar(255) @map("team_id")
  matchId         String?   @db.VarChar(255) @map("match_id")
  metadata        String?
  playRequestId   Int? @map("play_request_id")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("connection_notifications")
}

model ContactRequests {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  name       String
  email      String
  phone      String?
  message    String
  type       String    @default("Contact Form")
  createdAt  DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  isRead     Boolean?  @default(false) @map("is_read")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("contact_requests")
}

model EventAttendees {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId       String    @db.VarChar(36) @map("event_id")
  userId        String    @db.VarChar(255) @map("user_id")
  createdAt     DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  status        String    @default("attending") @db.VarChar(20)
  ticketNumber  Int? @map("ticket_number")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("event_attendees")
}

model EventCategories {
  id          Int       @id @default(autoincrement())
  name        String
  icon        String?   @default("calendar")
  orderIndex  Int?      @default(0) @map("order_index")
  createdAt   DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@unique([name, tenantId])
  @@map("event_categories")
}

model EventEntries {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId             String    @db.VarChar(36) @map("event_id")
  userId              String    @db.VarChar(36) @map("user_id")
  teamName            String? @map("team_name")
  playerNames         Json?     @default("[]") @db.Json @map("player_names")
  enteredAt           DateTime? @default(now()) @db.Timestamp(6) @map("entered_at")
  paymentStatus       String?   @default("pending") @map("payment_status")
  paymentAmount       String? @map("payment_amount")
  signupType          String?   @default("team") @map("signup_type")
  playerCount         Int?      @default(1) @map("player_count")
  assignedPlayerIds   Json?     @default("[]") @map("assigned_player_ids")
  score               Int?
  playerScores        Json?     @default("{}") @db.Json @map("player_scores")
  stripePaymentId     String? @map("stripe_payment_id")
  playerHandicaps     Json?     @default("{}") @db.Json @map("player_handicaps")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("event_entries")
}

model EventSuggestions {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  userId            String    @db.VarChar(255) @map("user_id")
  name              String
  startDate         String @map("start_date")
  endDate           String? @map("end_date")
  venueName         String @map("venue_name")
  address           String
  summary           String
  description       String
  imageUrl          String? @map("image_url")
  tags              Json?     @default("[]") @db.Json
  ticketUrl         String? @map("ticket_url")
  status            String    @default("pending")
  createdAt         DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  reviewedAt        DateTime? @db.Timestamp(6) @map("reviewed_at")
  reviewedBy        String?   @db.VarChar(255) @map("reviewed_by")
  rejectionReason   String? @map("rejection_reason")
  groupEventId      String?   @db.VarChar(36) @map("group_event_id")
  approvedEventId   String?   @db.VarChar(36) @map("approved_event_id")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("event_suggestions")
}

model Events {
  id                            String   @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  name                          String
  startDate                     String @map("start_date")
  endDate                       String? @map("end_date")
  venueName                     String @map("venue_name")
  address                       String
  summary                       String
  description                   String
  imageUrl                      String @map("image_url")
  tags                          Json?    @default("[]") @db.Json
  ticketUrl                     String? @map("ticket_url")
  isFeatured                    Boolean? @default(false) @map("is_featured")
  slug                          String
  isEventGroup                  Boolean? @default(false) @map("is_event_group")
  linkedGroupId                 String?  @db.VarChar(36) @map("linked_group_id")
  isCarousel                    Boolean? @default(false) @map("is_carousel")
  eventType                     String?  @default("standard") @map("event_type")
  maxEntries                    Int? @map("max_entries")
  teamSize                      Int? @map("team_size")
  entryFee                      String? @map("entry_fee")
  signupDeadline                String? @map("signup_deadline")
  competitionFormat             String? @map("competition_format")
  allowIndividualStableford     Boolean? @default(false) @map("allow_individual_stableford")
  stripeProductId               String? @map("stripe_product_id")
  stripePriceId                 String? @map("stripe_price_id")
  leagueTableSortOrder          String?  @default("highest_first") @map("league_table_sort_order")
  allowTeamHandicap             Boolean? @default(false) @map("allow_team_handicap")
  adminLastSeenEntrantCount     Int?     @default(0) @map("admin_last_seen_entrant_count")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@unique([slug, tenantId])
  @@map("events")
}

model GroupEventComments {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId           String    @db.VarChar(36) @map("event_id")
  userId            String    @db.VarChar(255) @map("user_id")
  parentCommentId   String?   @db.VarChar(36) @map("parent_comment_id")
  content           String
  createdAt         DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("group_event_comments")
}

model GroupEventReactions {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  eventId       String @db.VarChar(36) @map("event_id")
  userId        String @db.VarChar(255) @map("user_id")
  reactionType  String @map("reaction_type")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("group_event_reactions")
}

model GroupEvents {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  groupId        String    @db.VarChar(36) @map("group_id")
  userId         String    @db.VarChar(255) @map("user_id")
  name           String
  startDate      String @map("start_date")
  endDate        String? @map("end_date")
  venueName      String @map("venue_name")
  address        String
  summary        String
  description    String
  imageUrl       String? @map("image_url")
  tags           Json?     @default("[]") @db.Json
  ticketUrl      String? @map("ticket_url")
  showOnPublic   Boolean?  @default(false) @map("show_on_public")
  createdAt      DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("group_events")
}

model GroupMemberships {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  groupId      String    @db.VarChar(36) @map("group_id")
  userId       String    @db.VarChar(255) @map("user_id")
  role         String    @default("member")
  status       String    @default("pending")
  requestedAt  DateTime? @default(now()) @db.Timestamp(6) @map("requested_at")
  approvedAt   DateTime? @db.Timestamp(6) @map("approved_at")
  approvedBy   String?   @db.VarChar(255) @map("approved_by")

  tenantId     String?   @db.VarChar @map("tenant_id")
  @@unique([groupId, userId], map: "group_member_unique")
  @@map("group_memberships")
}

model GroupPostComments {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  postId            String    @db.VarChar(36) @map("post_id")
  userId            String    @db.VarChar(255) @map("user_id")
  parentCommentId   String?   @db.VarChar(36) @map("parent_comment_id")
  content           String
  createdAt         DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("group_post_comments")
}

model GroupPostReactions {
  id            String @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  postId        String @db.VarChar(36) @map("post_id")
  userId        String @db.VarChar(255) @map("user_id")
  reactionType  String @map("reaction_type")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("group_post_reactions")
}

model GroupPosts {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  groupId    String    @db.VarChar(36) @map("group_id")
  userId     String    @db.VarChar(255) @map("user_id")
  content    String
  imageUrls  Json?     @default("[]") @db.Json @map("image_urls")
  createdAt  DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  updatedAt  DateTime? @db.Timestamp(6) @map("updated_at")
  edited     Boolean?  @default(false)
  category   String    @default("Social")
  postType   String    @default("post") @map("post_type")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@map("group_posts")
}

model Groups {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  name        String
  slug        String
  description String
  imageUrl    String? @map("image_url")
  createdBy   String    @db.VarChar(255) @map("created_by")
  createdAt   DateTime? @default(now()) @db.Timestamp(6) @map("created_at")
  isActive    Boolean?  @default(true) @map("is_active")
  isPublic    Boolean?  @default(false) @map("is_public")
  eventId     String?   @db.VarChar(36) @map("event_id")
  tenantId     String?   @db.VarChar @map("tenant_id")
  @@unique([slug, tenantId])
  @@map("groups")
}

model HeroSettings {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.VarChar(36)
  title     String
  subtitle  String
  imageUrl  String @map("image_url")
  ctaText   String? @map("cta_text")
  ctaLink   String? @map("cta_link")
  tenantId     String?   @db.VarChar @map("tenant_id")
